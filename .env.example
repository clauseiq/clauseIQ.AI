# ─── AI ─────────────────────────────────────────────────────────────────────
# Google Gemini API Key — backend only (never expose to frontend)
# Get from: https://aistudio.google.com/
GEMINI_API_KEY=

# ─── Supabase ────────────────────────────────────────────────────────────────
# Supabase Project URL (safe for VITE_ prefix — used in both frontend & backend)
VITE_SUPABASE_URL=
# Supabase Anon (public) key — safe to expose to frontend
VITE_SUPABASE_ANON_KEY=
# Supabase Service Role key — BACKEND ONLY, NEVER commit or expose to frontend
# Used for admin DB writes that bypass RLS (e.g., incrementing credits server-side)
SUPABASE_SERVICE_ROLE_KEY=

# ─── Razorpay ────────────────────────────────────────────────────────────────
# Razorpay Key ID — used on frontend (safe to expose)
RAZORPAY_KEY_ID=
# Razorpay Key Secret — BACKEND ONLY, NEVER expose to frontend or logs
RAZORPAY_KEY_SECRET=

# ─── Application ─────────────────────────────────────────────────────────────
# Your deployed URL — used for CORS and email redirects
# Production: https://your-project.vercel.app or https://clauseiq.com
# Local:      http://localhost:3000
VITE_SITE_URL=http://localhost:3000

# Admin / privileged email — bypasses scan limits (used in backend only)
ADMIN_EMAIL=clauseiq.dev2026@gmail.com

# ─── Dev / Demo Mode ─────────────────────────────────────────────────────────
# Set to 'true' to return mock AI responses (saves quota, no API key needed)
# Set to 'false' for real Gemini analysis
MOCK_AI_RESPONSE=true
